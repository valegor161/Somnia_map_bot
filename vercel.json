{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "functions": {
    "api/webhook.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "api/webhook.py" }
  ]
}
